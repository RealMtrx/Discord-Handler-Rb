# Bot Configuration
TOKEN=your_bot_token_here
PREFIX=!
BOT_NAME=Discord Handler
OWNER_ID=your_discord_id

# MongoDB
MONGO_URI=mongodb://localhost:27017/discord-handler

# Webhooks
ERROR_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
GUILD_LOG_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
